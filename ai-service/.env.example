# =============================================================================
# PRODFLOW AI - AI SERVICE ENVIRONMENT CONFIGURATION
# =============================================================================

# Server Configuration
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development

# Model Configuration
MODEL_PATH=sprint_success_model.pkl
METADATA_PATH=model_metadata.pkl
MODEL_VERSION=2.0.0

# API Configuration
API_TITLE=ProdFlow AI Service
API_VERSION=2.0.0
API_DESCRIPTION=Advanced Sprint Success Prediction using Ensemble Machine Learning

# CORS Configuration
CORS_ORIGINS=["https://prodflowaii.vercel.app", "http://localhost:3000", "http://localhost:5000"]

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Performance Configuration
MAX_WORKERS=4
TIMEOUT=30
KEEP_ALIVE=2

# Feature Flags
ENABLE_DETAILED_PREDICTIONS=true
ENABLE_MODEL_INFO_ENDPOINT=true
ENABLE_HEALTH_CHECK=true