# ProdFlow AI Services - Environment Configuration
# Copy this to .env and fill in your values

# =============================================================================
# GENERAL CONFIGURATION
# =============================================================================
ENVIRONMENT=production
HOST=0.0.0.0

# =============================================================================
# SPRINT PREDICTION SERVICE (main.py) - Port 8000
# =============================================================================
PORT=8000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/prodflow-ai?retryWrites=true&w=majority

# =============================================================================
# PERFORMANCE ANALYSIS SERVICE (performance_api.py) - Port 8001
# =============================================================================
PERFORMANCE_PORT=8001
BACKEND_API_URL=https://your-backend-url.com/api
AI_SERVICE_API_KEY=your-secret-api-key-here

# =============================================================================
# SHARED CONFIGURATION
# =============================================================================
CORS_ORIGINS=["https://your-frontend-url.com"]

# ML Configuration
ML_CLUSTERING_ENABLED=true
ML_RISK_PREDICTION_ENABLED=true
ML_MIN_DATA_POINTS=10

# Performance Thresholds
HIGH_PERFORMER_THRESHOLD=80.0
AVERAGE_PERFORMER_THRESHOLD=60.0

# Developer Efficiency Weights (must sum to 1.0)
DEV_COMPLETION_SPEED_WEIGHT=0.35
DEV_CODE_QUALITY_WEIGHT=0.25
DEV_COMPLETION_RATE_WEIGHT=0.25
DEV_DEADLINE_CONSISTENCY_WEIGHT=0.15

# Team Lead Efficiency Weights (must sum to 1.0)
TL_PLANNING_QUALITY_WEIGHT=0.35
TL_REVIEW_RESPONSIVENESS_WEIGHT=0.30
TL_TASK_DISTRIBUTION_WEIGHT=0.20
TL_SPRINT_SUCCESS_WEIGHT=0.15

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# Optional: Redis Cache
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
CACHE_TTL=3600
