# AI Team Performance Analysis Service - PRODUCTION Configuration

# Service Configuration
ENVIRONMENT=production
HOST=0.0.0.0
PORT=8001

# Backend API Configuration
# Your deployed backend URL (e.g., https://your-backend.railway.app/api)
BACKEND_API_URL=https://YOUR_BACKEND_URL_HERE/api
# Must match the AI_SERVICE_API_KEY in backend .env
AI_SERVICE_API_KEY=CHANGE_THIS_TO_SAME_KEY_AS_BACKEND

# CORS Configuration
# Your deployed frontend URL (e.g., https://your-app.vercel.app)
CORS_ORIGINS=["https://YOUR_FRONTEND_URL_HERE"]

# ML Configuration
ML_CLUSTERING_ENABLED=true
ML_RISK_PREDICTION_ENABLED=true
ML_MIN_DATA_POINTS=10

# Performance Thresholds
HIGH_PERFORMER_THRESHOLD=80.0
AVERAGE_PERFORMER_THRESHOLD=60.0

# Developer Efficiency Weights (must sum to 1.0)
DEV_COMPLETION_SPEED_WEIGHT=0.35
DEV_CODE_QUALITY_WEIGHT=0.25
DEV_COMPLETION_RATE_WEIGHT=0.25
DEV_DEADLINE_CONSISTENCY_WEIGHT=0.15

# Team Lead Efficiency Weights (must sum to 1.0)
TL_PLANNING_QUALITY_WEIGHT=0.35
TL_REVIEW_RESPONSIVENESS_WEIGHT=0.30
TL_TASK_DISTRIBUTION_WEIGHT=0.20
TL_SPRINT_SUCCESS_WEIGHT=0.15

# API Configuration
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# Redis Cache (Optional - set to true if using Redis)
REDIS_ENABLED=false
REDIS_HOST=your-redis-host.com
REDIS_PORT=6379
REDIS_DB=0
CACHE_TTL=3600
