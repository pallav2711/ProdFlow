# =============================================================================
# PRODFLOW AI - FRONTEND ENVIRONMENT CONFIGURATION
# =============================================================================

# API Configuration
VITE_API_BASE_URL=https://prodflow-6rmm.onrender.com/api
VITE_AI_SERVICE_URL=http://localhost:8000

# App Configuration
VITE_APP_NAME=ProdFlow AI
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Sprint Planning SaaS with AI Predictions

# Environment
VITE_NODE_ENV=development

# Feature Flags
VITE_ENABLE_AI_PREDICTIONS=true
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=true

# UI Configuration
VITE_DEFAULT_THEME=light
VITE_ENABLE_DARK_MODE=true