# ProdFlow AI - Frontend Production Environment

# API URLs
# Your deployed backend URL (e.g., https://your-backend.railway.app/api)
VITE_API_URL=https://YOUR_BACKEND_URL_HERE/api

# Your deployed AI service URL (e.g., https://your-ai-service.railway.app)
VITE_AI_SERVICE_URL=https://YOUR_AI_SERVICE_URL_HERE

# Environment
VITE_ENV=production

# Optional: Analytics
VITE_ANALYTICS_ID=your-analytics-id-here

# Optional: Sentry Error Tracking
VITE_SENTRY_DSN=your-sentry-dsn-here
