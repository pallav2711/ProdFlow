{
  "name": "prodflow-ai-backend",
  "version": "1.0.0",
  "description": "Backend API for ProdFlow AI - Sprint Planning SaaS with AI Predictions",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js --inspect",
    "prod": "NODE_ENV=production node --max-old-space-size=512 server.js",
    "cluster": "NODE_ENV=production node cluster.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint .",
    "build": "echo \"Backend build complete\"",
    "postinstall": "echo \"Backend dependencies installed successfully\"",
    "profile": "node --prof server.js",
    "analyze-profile": "node --prof-process isolate-*.log > profile.txt"
  },
  "keywords": ["saas", "sprint-planning", "ai", "project-management", "nodejs", "express", "mongodb"],
  "author": "ProdFlow AI Team",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^8.0.3",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "express-validator": "^7.0.1",
    "axios": "^1.6.2",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "redis": "^4.6.0",
    "ioredis": "^5.3.2",
    "express-slow-down": "^2.0.1",
    "express-mongo-sanitize": "^2.2.0",
    "hpp": "^0.2.3",
    "cluster": "^0.7.7"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "eslint": "^8.55.0",
    "clinic": "^12.0.0",
    "autocannon": "^7.12.0"
  }
}
