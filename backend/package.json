{
  "name": "prodflow-ai-backend",
  "version": "1.0.0",
  "description": "Backend API for ProdFlow AI - Sprint Planning SaaS with AI Predictions",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "prod": "NODE_ENV=production node server.js",
    "test": "node tests/integration/smoke.test.js",
    "test:fast": "set TEST_SMOKE_MODE=fast&& node tests/integration/smoke.test.js",
    "test:full": "set TEST_SMOKE_MODE=full&& node tests/integration/smoke.test.js",
    "lint": "eslint .",
    "build": "echo \"Backend build complete\"",
    "postinstall": "echo \"Backend dependencies installed successfully\""
  },
  "keywords": [
    "saas",
    "sprint-planning",
    "ai",
    "project-management",
    "nodejs",
    "express",
    "mongodb"
  ],
  "author": "ProdFlow AI Team",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "eslint": "^8.55.0",
    "nodemon": "^3.0.2"
  }
}
