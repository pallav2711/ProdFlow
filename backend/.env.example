# =============================================================================
# PRODFLOW AI - BACKEND ENVIRONMENT CONFIGURATION
# =============================================================================

# Server Configuration
PORT=5000
NODE_ENV=production
HOST=0.0.0.0

# Database Configuration
# Use your own MongoDB URI (never commit real credentials)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<db-name>?retryWrites=true&w=majority
# Development alternative:
# MONGODB_URI=mongodb://localhost:27017/prodflow-ai

# Security Configuration
JWT_SECRET=replace-with-strong-jwt-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret-min-32-chars
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d
BCRYPT_ROUNDS=12

# AI Service Configuration
AI_SERVICE_URL=https://your-ai-service-domain.example.com
AI_REQUEST_TIMEOUT_MS=4000
AI_MAX_RETRIES=1
AI_RETRY_BASE_DELAY_MS=300

# CORS Configuration
FRONTEND_URL=https://your-frontend-domain.example.com
# Development alternative:
# FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Health Check
HEALTH_CHECK_INTERVAL=30000

# HTTP Server timeouts
SERVER_REQUEST_TIMEOUT_MS=30000
SERVER_HEADERS_TIMEOUT_MS=35000
SERVER_KEEP_ALIVE_TIMEOUT_MS=5000
