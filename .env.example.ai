# ═══════════════════════════════════════════════════════════════════════════════
# ProdFlow AI - AI Service Environment Configuration (Example)
# ═══════════════════════════════════════════════════════════════════════════════
#
# INSTRUCTIONS:
# 1. Copy this file to `.env` in the ai-service directory
# 2. Replace placeholder values with your actual configuration
# 3. Never commit the actual .env file to version control
#
# ═══════════════════════════════════════════════════════════════════════════════

# ── Server Configuration ───────────────────────────────────────────────────────
# Environment: development | production
ENVIRONMENT=development

# Server port
PORT=8000

# Server host
HOST=0.0.0.0

# ── Backend API Configuration ──────────────────────────────────────────────────
# Backend API URL for fetching analytics data
# Development: http://localhost:5000/api
# Production: https://your-backend-domain.com/api
BACKEND_API_URL=http://localhost:5000/api

# API Key for secure communication with backend
# Must match AI_SERVICE_API_KEY in backend .env
API_KEY=your_ai_service_api_key_here

# ── AI/ML Configuration ────────────────────────────────────────────────────────
# Model training parameters
MODEL_TRAINING_ENABLED=true
MODEL_AUTO_RETRAIN=false
MODEL_RETRAIN_INTERVAL_DAYS=7

# Prediction confidence threshold (0.0 to 1.0)
PREDICTION_CONFIDENCE_THRESHOLD=0.7

# ── Cache Configuration ────────────────────────────────────────────────────────
# Enable caching for analytics data
CACHE_ENABLED=true

# Cache TTL in seconds
CACHE_TTL=300

# Cache type: memory | redis
CACHE_TYPE=memory

# Redis configuration (if CACHE_TYPE=redis)
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=your_redis_password

# ── Performance Configuration ──────────────────────────────────────────────────
# Number of worker processes (0 = auto-detect CPU cores)
WORKERS=0

# Request timeout (seconds)
REQUEST_TIMEOUT=30

# Max request size (MB)
MAX_REQUEST_SIZE=10

# ── Logging ────────────────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Log format: json | text
LOG_FORMAT=json

# Log file path (optional)
LOG_FILE=logs/ai-service.log

# ── Data Processing ────────────────────────────────────────────────────────────
# Minimum data points required for predictions
MIN_DATA_POINTS=10

# Historical data window (days)
HISTORICAL_DATA_WINDOW_DAYS=90

# ── Feature Engineering ────────────────────────────────────────────────────────
# Enable advanced feature engineering
ADVANCED_FEATURES_ENABLED=true

# Feature scaling method: standard | minmax | robust
FEATURE_SCALING_METHOD=standard

# ── Model Configuration ────────────────────────────────────────────────────────
# Model type: random_forest | gradient_boosting | neural_network
MODEL_TYPE=random_forest

# Model hyperparameters (JSON format)
MODEL_HYPERPARAMETERS={"n_estimators": 100, "max_depth": 10, "random_state": 42}

# ── Health Check ───────────────────────────────────────────────────────────────
# Health check endpoint enabled
HEALTH_CHECK_ENABLED=true

# Health check interval (seconds)
HEALTH_CHECK_INTERVAL=30

# ── Optional: External Services ────────────────────────────────────────────────
# OpenAI API Key (for advanced AI features)
# OPENAI_API_KEY=your_openai_api_key_here

# Hugging Face API Key (for NLP models)
# HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# ═══════════════════════════════════════════════════════════════════════════════
# End of AI Service Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
