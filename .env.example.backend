# ═══════════════════════════════════════════════════════════════════════════════
# ProdFlow AI - Backend Environment Configuration (Example)
# ═══════════════════════════════════════════════════════════════════════════════
#
# INSTRUCTIONS:
# 1. Copy this file to `.env` in the backend directory
# 2. Replace placeholder values with your actual configuration
# 3. NEVER commit the actual .env file to version control
# 4. Generate secure secrets using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# ═══════════════════════════════════════════════════════════════════════════════

# ── Server Configuration ───────────────────────────────────────────────────────
# Environment: development | production
NODE_ENV=development

# Server port
PORT=5000

# Server host (0.0.0.0 for all interfaces, localhost for local only)
HOST=0.0.0.0

# ── Database Configuration ─────────────────────────────────────────────────────
# MongoDB connection string
# Local: mongodb://localhost:27017/prodflow-ai
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/prodflow-ai?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/prodflow-ai

# Database Connection Pool (Performance Optimization)
MONGODB_MAX_POOL_SIZE=50
MONGODB_MIN_POOL_SIZE=5

# ── Security Configuration ─────────────────────────────────────────────────────
# JWT Secret for access tokens (REQUIRED - Generate a secure random string)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_here

# JWT Refresh Secret for refresh tokens (REQUIRED - Must be different from JWT_SECRET)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_min_32_chars_here

# JWT Expiration times
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Bcrypt rounds for password hashing (10-12 recommended)
BCRYPT_ROUNDS=12

# ── CORS Configuration ─────────────────────────────────────────────────────────
# Frontend URL for CORS (comma-separated for multiple origins)
# Development: http://localhost:3000,http://localhost:5173
# Production: https://your-frontend-domain.com
FRONTEND_URL=http://localhost:5173

# ── AI Service Configuration ───────────────────────────────────────────────────
# AI Service URL (Python microservice)
# Development: http://localhost:8000
# Production: https://your-ai-service-domain.com
AI_SERVICE_URL=http://localhost:8000

# AI Service API Key (for secure communication between services)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AI_SERVICE_API_KEY=your_ai_service_api_key_here

# AI Service Performance Settings
AI_REQUEST_TIMEOUT_MS=4000
AI_MAX_RETRIES=1
AI_RETRY_BASE_DELAY_MS=300

# ── Server Performance Tuning ──────────────────────────────────────────────────
# Request timeout (milliseconds)
SERVER_REQUEST_TIMEOUT_MS=20000

# Headers timeout (must be > request timeout)
SERVER_HEADERS_TIMEOUT_MS=25000

# Keep-alive timeout for connection reuse
SERVER_KEEP_ALIVE_TIMEOUT_MS=65000

# Max concurrent connections (0 = unlimited)
SERVER_MAX_CONNECTIONS=0

# ── Background Job Queue ───────────────────────────────────────────────────────
# Number of concurrent background jobs
JOB_QUEUE_CONCURRENCY=5

# ── Rate Limiting ──────────────────────────────────────────────────────────────
# Global rate limit window (milliseconds)
RATE_LIMIT_WINDOW_MS=900000

# Global rate limit max requests per window
RATE_LIMIT_MAX_REQUESTS=500

# Auth rate limit max requests per window
AUTH_RATE_LIMIT_MAX=10

# ── Logging ────────────────────────────────────────────────────────────────────
# Log level: error | warn | info | debug
LOG_LEVEL=info

# Log file path (optional)
LOG_FILE=logs/app.log

# ── Health Check ───────────────────────────────────────────────────────────────
# Health check interval (milliseconds)
HEALTH_CHECK_INTERVAL=30000

# ── Optional: Redis Cache (for multi-server deployments) ──────────────────────
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=your_redis_password
# REDIS_TLS=true

# ── Optional: APM / Monitoring ─────────────────────────────────────────────────
# NEW_RELIC_LICENSE_KEY=your_new_relic_key
# SENTRY_DSN=your_sentry_dsn

# ═══════════════════════════════════════════════════════════════════════════════
# End of Backend Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
