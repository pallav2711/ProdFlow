# ═══════════════════════════════════════════════════════════════════════════════
# ProdFlow AI - .gitignore
# Professional open-source repository configuration
# ═══════════════════════════════════════════════════════════════════════════════

# ── Environment Variables (SECURITY CRITICAL) ──────────────────────────────────
# Never commit actual environment files with secrets
.env
.env.local
.env.development
.env.test
.env.production.*
*.env

# Exception: Keep example files for documentation
!.env.example
!.env.example.*

# ── Dependencies ───────────────────────────────────────────────────────────────
# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json.backup

# Python
venv/
env/
ENV/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
dist/
build/
pip-log.txt
pip-delete-this-directory.txt

# ── Build Outputs ──────────────────────────────────────────────────────────────
dist/
build/
out/
.next/
.nuxt/
*.tsbuildinfo

# ── IDE & Editors ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.swn
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# ── Operating System ───────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Logs ───────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
lerna-debug.log*
pnpm-debug.log*

# ── Testing & Coverage ─────────────────────────────────────────────────────────
coverage/
.nyc_output/
.pytest_cache/
.coverage
htmlcov/
*.cover
.hypothesis/

# ── Temporary Files ────────────────────────────────────────────────────────────
*.tmp
*.temp
*.bak
*.backup
.cache/
.parcel-cache/

# ── Database Files ─────────────────────────────────────────────────────────────
*.sqlite
*.sqlite3
*.db

# ── Credentials & Secrets ──────────────────────────────────────────────────────
credentials/
secrets/
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx

# ── Development Scripts (Windows) ──────────────────────────────────────────────
start-all-services.bat
stop-all-services.bat
restart-*.bat
force-*.bat
diagnose-*.bat
test-*.bat
START_*.bat
check-*.bat
fix-*.bat

# ── AI/ML Models (too large for git) ───────────────────────────────────────────
*.h5
*.pkl
*.pickle
*.joblib
*.model
models/*.pkl
models/*.h5

# ── Miscellaneous ──────────────────────────────────────────────────────────────
.env.backup
*.orig

# ═══════════════════════════════════════════════════════════════════════════════
# End of .gitignore
# ═══════════════════════════════════════════════════════════════════════════════
